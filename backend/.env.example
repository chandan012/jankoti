# Server Configuration
PORT=5000
NODE_ENV=production

# Frontend URL (for redirects)
FRONTEND_URL=https://entrepreneur.jankoti.com

# MongoDB Connection (Atlas)
MONGODB_URI=your_mongodb_uri

# JWT Secret - Used for secure user authentication
JWT_SECRET=your_jwt_secret

# Session Secret - Used for server session management
SESSION_SECRET=your_session_secret

# OpenAI API Key for AI Banner Generation
OPENAI_API_KEY=your_openai_api_key

# Google OAuth - Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google OAuth Callback URL (Production)
GOOGLE_CALLBACK_URL=https://entrepreneur.jankoti.com/api/auth/google/callback

# HuggingFace API Key
HUGGINGFACE_API_KEY=your_huggingface_api_key

# Zoho Mail SMTP
ZOHO_HOST=smtp.zoho.in
ZOHO_PORT=465
ZOHO_USER=your_zoho_user
ZOHO_PASS=your_zoho_pass

# Admin access (comma-separated emails)
ADMIN_EMAILS=you@example.com

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
